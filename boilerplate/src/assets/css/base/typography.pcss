@layer utilities {
	.h1 {
		@apply font-normal text-[2.5rem] md:text-[4.375rem] leading-[1.2];
	}

	.h2 {
		@apply font-normal text-[2rem] md:text-[2.5rem] leading-[1.2];
	}

	.body {
		@apply font-body font-normal text-base md:text-[1.25rem] leading-[1.6] md:leading-normal;
	}

	.small {
		@apply font-body font-normal text-[0.875rem] md:text-[1.125rem] leading-[1.4];
	}
}